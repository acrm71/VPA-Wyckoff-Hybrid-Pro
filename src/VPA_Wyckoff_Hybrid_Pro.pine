const int CFG_WARN_SCORING_INSUFFICIENT_MODULES = 5
const int CFG_WARN_ALERTS_SIGNAL_MODE_REQUIRES_SCORING = 6
// Trend states.
//
// Numeric values are append-only after implementation begins.
const int TREND_UNAVAILABLE = 0
const int TREND_NEUTRAL = 1
const int TREND_BULLISH = 2
const int TREND_BEARISH = 3
const int TREND_STRONG_BULLISH = 4
const int TREND_STRONG_BEARISH = 5
// Trend slope states.
const int TREND_SLOPE_BEARISH = -1
const int TREND_SLOPE_FLAT = 0
const int TREND_SLOPE_BULLISH = 1

// Trend alignment states.
const int TREND_ALIGN_BEARISH = -1
const int TREND_ALIGN_MIXED = 0
const int TREND_ALIGN_BULLISH = 1
// =============================================================================
// 02. INPUT GROUP NAMES
// =============================================================================

