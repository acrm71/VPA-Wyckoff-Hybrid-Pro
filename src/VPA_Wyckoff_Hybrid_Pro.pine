const string GROUP_PROFILES = "01 — Profiles"
const string GROUP_TREND = "02 — Trend"
const string GROUP_RVOL = "03 — Relative Volume"
const string GROUP_STRUCTURE = "04 — Market Structure"
const string GROUP_BOS = "05 — BOS and CHOCH"
const string GROUP_LIQUIDITY = "06 — Liquidity"
const string GROUP_VPA = "07 — VPA"
