//@version=6
indicator(
     title = "VPA Wyckoff Hybrid Pro Professional",
     shorttitle = "VPA-WH Pro",
     overlay = true,
     max_bars_back = 5000,
     max_labels_count = 500,
     max_lines_count = 500,
     max_boxes_count = 500
)

// =============================================================================
// VPA WYCKOFF HYBRID PRO PROFESSIONAL
// Version: 0.2.1-dev
//
// Current implementation phase:
// Phase 1 — Shared foundation, framework context, and module contracts
//
// This script is an indicator only.
// It does not execute trades.
// =============================================================================

// =============================================================================
// 01. SHARED CONSTANTS AND ENUMERATIONS
// =============================================================================

// Direction.
const int DIR_BEARISH = -1
const int DIR_NEUTRAL = 0
const int DIR_BULLISH = 1

// Availability.
const int AVAIL_DISABLED = 0
const int AVAIL_UNAVAILABLE = 1
const int AVAIL_AVAILABLE = 2

// Lifecycle.
const int LIFE_DISABLED = 0
const int LIFE_UNAVAILABLE = 1
const int LIFE_CANDIDATE = 2
const int LIFE_CONFIRMED = 3
const int LIFE_REINFORCED = 4
const int LIFE_WEAKENING = 5
const int LIFE_FAILED = 6
const int LIFE_INVALIDATED = 7
const int LIFE_EXPIRED = 8
const int LIFE_COMPLETED = 9

// Module identifiers.
const int MODULE_FRAMEWORK = 0
const int MODULE_TREND = 1
const int MODULE_RVOL = 2
const int MODULE_STRUCTURE = 3
const int MODULE_BOS = 4
const int MODULE_LIQUIDITY = 5
const int MODULE_VPA = 6
const int MODULE_WYCKOFF = 7
const int MODULE_INSTITUTIONAL = 8
const int MODULE_SCORING = 9
const int MODULE_DASHBOARD = 10
const int MODULE_ALERTS = 11

// Dependency types.
const int DEP_NONE = 0
const int DEP_OPTIONAL = 1
const int DEP_SOFT = 2
const int DEP_HARD = 3

// Warning severity.
