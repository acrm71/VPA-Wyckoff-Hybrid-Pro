// =============================================================================
// 04. USER-DEFINED TYPES
// =============================================================================
// Coordinated profile thresholds.
type ProfileSettings
    float minimumSignalConfidence
    float minimumSetupQuality
    float minimumEntryReadiness
    int minimumConfirmingModules
    float directionalDominance
    int stateConfirmationBars
    float minimumAlertConfidence
    int alertCooldownBars

// Complete resolved settings snapshot.
//
// Raw TradingView inputs are converted into this contract before analytical
// modules execute. Downstream modules shall consume this snapshot rather than
// interpreting profile strings independently.
type EffectiveSettings
    bool indicatorEnabled

    int profile
    int confirmationMode
    bool confirmedBarOnly
    bool developingAllowed
    bool productionEventAllowed

    int atrLength
    int minimumHistoryBars

    bool trendEnabled
    bool rvolEnabled
    bool structureEnabled

    bool bosRequested
    bool bosDependencyValid

    bool liquidityRequested
    bool liquidityDependencyValid

    bool vpaEnabled

    bool wyckoffRequested
    bool wyckoffDependencyValid

    bool institutionalEnabled
    bool scoringEnabled
    bool dashboardEnabled
    bool alertsEnabled

    float minimumSignalConfidence
    float minimumSetupQuality
    float minimumEntryReadiness
    int minimumConfirmingModules
    float directionalDominance
    int stateConfirmationBars
    float minimumAlertConfidence
    int alertCooldownBars

    bool configurationValid
    int warningCount
    int highestWarningSeverity
    int highestWarningCode
// Common output fields shared conceptually by all analytical modules.
type ModuleOutput
    bool enabled
    bool available
    bool sufficientHistory
    bool configurationValid
    bool dependencyValid
    int state
    int direction
    int lifecycle
    float confidence
    int eventId
    bool newEvent
    int creationBar
    int confirmationBar
   // Trend Engine output snapshot.
//
// The base output preserves the common module contract. Additional fields
// publish Trend-specific state, scores, calculations, and transition metadata.
type TrendOutput
    ModuleOutput baseOutput

    int trendState
    int previousTrendState
    int trendDirection

    float trendStrength
    float trendConfidence
    float bullishScore
    float bearishScore

    float fastEma
    float slowEma
    float fastSlopeAtr
    float slowSlopeAtr

    int slopeState
    int alignmentState

    bool newTrendEvent
    int trendEventId 

// Shared framework snapshot.
type FrameworkOutput
    bool indicatorEnabled
    int currentBarIndex
    bool barConfirmed
    bool barRealtime
    bool barHistorical
    string symbol
    string timeframe
    float tickSize
    float atr
    bool volumeAvailable
    bool minimumHistoryMet
    bool debugEnabled

// =============================================================================
// 05. SHARED SAFETY HELPERS
// =============================================================================

clampConfidence(float value) =>
    math.max(0.0, math.min(100.0, value))

safeDivide(float numerator, float denominator, float fallback) =>
    not na(denominator) and denominator != 0.0
         ? numerator / denominator
         : fallback

isValidPrice(float value) =>
    not na(value) and value > 0.0

// =============================================================================
// 06. SHARED STRING-CONVERSION HELPERS
// =============================================================================
profileToId(string profileName) =>
    switch profileName
        "Conservative" => PROFILE_CONSERVATIVE
        "Balanced" => PROFILE_BALANCED
        "Aggressive" => PROFILE_AGGRESSIVE
        "Custom" => PROFILE_CUSTOM
        => PROFILE_BALANCED

confirmationModeToId(string confirmationName) =>
    switch confirmationName
        "Confirmed Bar Only" => CONFIRM_CONFIRMED_ONLY
        "Developing and Confirmed" => CONFIRM_DEVELOPING_AND_CONFIRMED
        "Developing Only" => CONFIRM_DEVELOPING_ONLY
        => CONFIRM_CONFIRMED_ONLY

profileToString(int profileId) =>
    switch profileId
        PROFILE_CONSERVATIVE => "Conservative"
        PROFILE_BALANCED => "Balanced"
        PROFILE_AGGRESSIVE => "Aggressive"
        PROFILE_CUSTOM => "Custom"
        => "Unknown"

confirmationModeToString(int confirmationMode) =>
    switch confirmationMode
        CONFIRM_CONFIRMED_ONLY => "Confirmed Bar Only"
        CONFIRM_DEVELOPING_AND_CONFIRMED => "Developing and Confirmed"
        CONFIRM_DEVELOPING_ONLY => "Developing Only"
        => "Unknown"

configurationWarningToString(int warningCode) =>
    switch warningCode
        CFG_WARN_NONE => "None"
        CFG_WARN_BOS_REQUIRES_STRUCTURE =>
            "BOS and CHOCH requires Market Structure"
        CFG_WARN_LIQUIDITY_REQUIRES_STRUCTURE =>
            "Liquidity requires Market Structure"
        CFG_WARN_LIQUIDITY_REQUIRES_BOS =>
            "Liquidity requires BOS and CHOCH"
        CFG_WARN_WYCKOFF_REQUIRES_STRUCTURE =>
            "Wyckoff requires Market Structure"
        CFG_WARN_SCORING_INSUFFICIENT_MODULES =>
            "Signal Scoring has insufficient analytical modules"
        CFG_WARN_ALERTS_SIGNAL_MODE_REQUIRES_SCORING =>
            "Signal alerts require Signal Scoring"
        => "Unknown configuration warning"
directionToString(int direction) =>
    switch direction
        DIR_BULLISH => "Bullish"
        DIR_BEARISH => "Bearish"
        => "Neutral"

lifecycleToString(int lifecycle) =>
    switch lifecycle
        LIFE_DISABLED => "Disabled"
        LIFE_UNAVAILABLE => "Unavailable"
        LIFE_CANDIDATE => "Candidate"
        LIFE_CONFIRMED => "Confirmed"
        LIFE_REINFORCED => "Reinforced"
        LIFE_WEAKENING => "Weakening"
        LIFE_FAILED => "Failed"
        LIFE_INVALIDATED => "Invalidated"
        LIFE_EXPIRED => "Expired"
        LIFE_COMPLETED => "Completed"
        => "Unknown"

moduleToString(int moduleId) =>
    switch moduleId
        MODULE_FRAMEWORK => "Framework"
        MODULE_TREND => "Trend"
        MODULE_RVOL => "RVOL"
        MODULE_STRUCTURE => "Market Structure"
        MODULE_BOS => "BOS and CHOCH"
        MODULE_LIQUIDITY => "Liquidity"
        MODULE_VPA => "VPA"
        MODULE_WYCKOFF => "Wyckoff"
        MODULE_INSTITUTIONAL => "Institutional Activity"
        MODULE_SCORING => "Signal Scoring"
        MODULE_DASHBOARD => "Dashboard"
        MODULE_ALERTS => "Alerts"
        => "Unknown"
trendStateToString(int trendState) =>
    switch trendState
        TREND_UNAVAILABLE => "Unavailable"
        TREND_NEUTRAL => "Neutral"
        TREND_BULLISH => "Bullish"
        TREND_BEARISH => "Bearish"
        TREND_STRONG_BULLISH => "Strong Bullish"
        TREND_STRONG_BEARISH => "Strong Bearish"
        => "Unknown"

trendSlopeStateToString(int slopeState) =>
    switch slopeState
        TREND_SLOPE_BULLISH => "Bullish"
        TREND_SLOPE_BEARISH => "Bearish"
        TREND_SLOPE_FLAT => "Flat"
        => "Unknown"

trendAlignmentStateToString(int alignmentState) =>
    switch alignmentState
        TREND_ALIGN_BULLISH => "Bullish"
        TREND_ALIGN_BEARISH => "Bearish"
        TREND_ALIGN_MIXED => "Mixed"
        => "Unknown"
trendStateToDirection(int trendState) =>
    switch trendState
        TREND_BULLISH => DIR_BULLISH
        TREND_STRONG_BULLISH => DIR_BULLISH
        TREND_BEARISH => DIR_BEARISH
        TREND_STRONG_BEARISH => DIR_BEARISH
        => DIR_NEUTRAL
isBullishTrendState(int trendState) =>
    trendState == TREND_BULLISH or trendState == TREND_STRONG_BULLISH

isBearishTrendState(int trendState) =>
    trendState == TREND_BEARISH or trendState == TREND_STRONG_BEARISH

resolveTrendTransitionTarget(int confirmedState, int candidateState) =>
    bool directBullishToBearish =
         isBullishTrendState(confirmedState) and
         isBearishTrendState(candidateState)

    bool directBearishToBullish =
         isBearishTrendState(confirmedState) and
         isBullishTrendState(candidateState)

    directBullishToBearish or directBearishToBullish
         ? TREND_NEUTRAL
         : candidateState      
trendSlopeAtr(float currentValue, float priorValue, float atrValue) =>
    bool valuesValid =
         not na(currentValue) and
         not na(priorValue) and
         not na(atrValue) and
         atrValue > 0.0

    valuesValid
         ? safeDivide(currentValue - priorValue, atrValue, 0.0)
         : 0.0
resolveTrendAlignment(
     float priceValue,
     float fastEma,
     float slowEma
) =>
    bool valuesValid =
         not na(priceValue) and
         not na(fastEma) and
         not na(slowEma)

    int alignmentState = TREND_ALIGN_MIXED

    if valuesValid
        if priceValue > fastEma and fastEma > slowEma
            alignmentState := TREND_ALIGN_BULLISH
        else if priceValue < fastEma and fastEma < slowEma
            alignmentState := TREND_ALIGN_BEARISH

    alignmentState
resolveTrendSlopeState(
     float fastSlopeAtr,
     float slowSlopeAtr,
     float slopeThresholdAtr
) =>
    float effectiveThreshold =
         math.max(0.0, slopeThresholdAtr)

    bool bullishSlope =
         fastSlopeAtr >= effectiveThreshold and
         slowSlopeAtr >= 0.0

    bool bearishSlope =
         fastSlopeAtr <= -effectiveThreshold and
         slowSlopeAtr <= 0.0

    bullishSlope
         ? TREND_SLOPE_BULLISH
         : bearishSlope
             ? TREND_SLOPE_BEARISH
             : TREND_SLOPE_FLAT
trendScoreDominance(
     float bullishScore,
     float bearishScore
) =>
    math.abs(
         clampConfidence(bullishScore) -
         clampConfidence(bearishScore)
     )
resolveTrendState(
     bool available,
     float bullishScore,
     float bearishScore,
     float trendThreshold,
     float strongThreshold,
     float dominanceThreshold
) =>
    float safeBullishScore =
         clampConfidence(bullishScore)

    float safeBearishScore =
         clampConfidence(bearishScore)

    float effectiveTrendThreshold =
         clampConfidence(trendThreshold)

    float effectiveStrongThreshold =
         math.max(
             effectiveTrendThreshold,
             clampConfidence(strongThreshold)
         )

    float effectiveDominanceThreshold =
         clampConfidence(dominanceThreshold)

    float dominance =
         trendScoreDominance(
             safeBullishScore,
             safeBearishScore
         )

    int resolvedState = TREND_NEUTRAL

    if not available
        resolvedState := TREND_UNAVAILABLE
    else if dominance < effectiveDominanceThreshold
        resolvedState := TREND_NEUTRAL
    else if safeBullishScore > safeBearishScore
        if safeBullishScore >= effectiveStrongThreshold
            resolvedState := TREND_STRONG_BULLISH
        else if safeBullishScore >= effectiveTrendThreshold
            resolvedState := TREND_BULLISH
    else if safeBearishScore > safeBullishScore
        if safeBearishScore >= effectiveStrongThreshold
            resolvedState := TREND_STRONG_BEARISH
        else if safeBearishScore >= effectiveTrendThreshold
            resolvedState := TREND_BEARISH

    resolvedState
resolveTrendConfidence(
     bool available,
     int trendState,
     float bullishScore,
     float bearishScore
) =>
    float safeBullishScore =
         clampConfidence(bullishScore)

    float safeBearishScore =
         clampConfidence(bearishScore)

    float dominantScore =
         math.max(
             safeBullishScore,
             safeBearishScore
         )

    float dominance =
         trendScoreDominance(
             safeBullishScore,
             safeBearishScore
         )

    float confidence =
         trendState == TREND_NEUTRAL
             ? 100.0 - dominance
             : dominantScore

    available
         ? clampConfidence(confidence)
         : 0.0

trendNormalisedStrength(float value, float referenceValue) =>
    float safeReference =
         math.max(math.abs(referenceValue), 0.000001)

    math.min(
         1.0,
         math.abs(value) / safeReference
     )               
resolveProfileSettings(int profileId) =>
    switch profileId
        PROFILE_CONSERVATIVE =>
            ProfileSettings.new(
                 75.0,
                 72.0,
                 75.0,
                 4,
                 20.0,
                 2,
                 75.0,
                 5
             )

        PROFILE_AGGRESSIVE =>
            ProfileSettings.new(
                 58.0,
                 58.0,
                 62.0,
                 2,
                 10.0,
                 1,
                 62.0,
                 1
             )

        PROFILE_CUSTOM =>
            ProfileSettings.new(
                 clampConfidence(inputCustomSignalConfidence),
                 clampConfidence(inputCustomSetupQuality),
                 clampConfidence(inputCustomEntryReadiness),
                 math.max(1, math.min(8, inputCustomConfirmingModules)),
                 clampConfidence(inputCustomDirectionalDominance),
                 math.max(1, math.min(10, inputCustomStateConfirmationBars)),
                 clampConfidence(inputCustomAlertConfidence),
                 math.max(0, math.min(100, inputCustomAlertCooldownBars))
             )

        =>
            ProfileSettings.new(
                 65.0,
                 65.0,
                 70.0,
                 3,
                 15.0,
                 1,
                 70.0,
                 3
             )
warningSeverityForCode(int warningCode) =>
    switch warningCode
        CFG_WARN_NONE => WARN_INFO
        CFG_WARN_BOS_REQUIRES_STRUCTURE => WARN_INVALID
        CFG_WARN_LIQUIDITY_REQUIRES_STRUCTURE => WARN_INVALID
        CFG_WARN_LIQUIDITY_REQUIRES_BOS => WARN_INVALID
        CFG_WARN_WYCKOFF_REQUIRES_STRUCTURE => WARN_INVALID
        CFG_WARN_SCORING_INSUFFICIENT_MODULES => WARN_DEGRADED
        CFG_WARN_ALERTS_SIGNAL_MODE_REQUIRES_SCORING => WARN_INVALID
        => WARN_INFO            
// =============================================================================
// 07. EFFECTIVE SETTINGS RESOLUTION
// =============================================================================

// Resolve user-facing option strings once.
int cfgProfileId = profileToId(inputProfile)
int cfgConfirmationModeId = confirmationModeToId(inputConfirmationMode)

// Resolve all profile-driven thresholds through one central function.
ProfileSettings cfgProfileSettings = resolveProfileSettings(cfgProfileId)

// Global operating state.
bool cfgIndicatorEnabled = inputIndicatorEnabled

bool cfgConfirmedBarOnly =
     cfgConfirmationModeId == CONFIRM_CONFIRMED_ONLY

bool cfgDevelopingAllowed =
     cfgConfirmationModeId == CONFIRM_DEVELOPING_AND_CONFIRMED or
     cfgConfirmationModeId == CONFIRM_DEVELOPING_ONLY

bool cfgProductionEventAllowed =
     cfgIndicatorEnabled and
     (
         cfgConfirmationModeId == CONFIRM_CONFIRMED_ONLY
             ? barstate.isconfirmed
             : cfgConfirmationModeId == CONFIRM_DEVELOPING_AND_CONFIRMED
                 ? true
                 : not barstate.isconfirmed
     )

// Resolve requested module states.
bool cfgTrendEnabled =
     cfgIndicatorEnabled and inputTrendEnabled

bool cfgRvolEnabled =
     cfgIndicatorEnabled and inputRvolEnabled

bool cfgStructureEnabled =
     cfgIndicatorEnabled and inputStructureEnabled

bool cfgBosRequested =
     cfgIndicatorEnabled and inputBosEnabled

bool cfgLiquidityRequested =
     cfgIndicatorEnabled and inputLiquidityEnabled

bool cfgVpaEnabled =
     cfgIndicatorEnabled and inputVpaEnabled

bool cfgWyckoffRequested =
     cfgIndicatorEnabled and inputWyckoffEnabled

bool cfgInstitutionalEnabled =
     cfgIndicatorEnabled and inputInstitutionalEnabled

bool cfgScoringEnabled =
     cfgIndicatorEnabled and inputScoringEnabled

bool cfgDashboardEnabled =
     cfgIndicatorEnabled and inputDashboardEnabled

bool cfgAlertsEnabled =
     cfgIndicatorEnabled and inputAlertsEnabled

// Resolve hard dependencies.
bool cfgBosDependencyValid =
     cfgStructureEnabled

bool cfgLiquidityStructureValid =
     cfgStructureEnabled

bool cfgLiquidityBosValid =
     cfgBosRequested and cfgBosDependencyValid

bool cfgLiquidityDependencyValid =
     cfgLiquidityStructureValid and cfgLiquidityBosValid

bool cfgWyckoffDependencyValid =
     cfgStructureEnabled

// Operational module states are useful for early execution skipping.
bool cfgBosOperational =
     cfgBosRequested and cfgBosDependencyValid

bool cfgLiquidityOperational =
     cfgLiquidityRequested and cfgLiquidityDependencyValid

bool cfgWyckoffOperational =
     cfgWyckoffRequested and cfgWyckoffDependencyValid

// Count analytical modules capable of contributing to Signal Scoring.
int cfgAvailableScoringModuleCount =
     (cfgTrendEnabled ? 1 : 0) +
     (cfgRvolEnabled ? 1 : 0) +
     (cfgStructureEnabled ? 1 : 0) +
     (cfgBosOperational ? 1 : 0) +
     (cfgLiquidityOperational ? 1 : 0) +
     (cfgVpaEnabled ? 1 : 0) +
     (cfgWyckoffOperational ? 1 : 0) +
     (cfgInstitutionalEnabled ? 1 : 0)

// Resolve configuration warnings.
int cfgWarningCount = 0
int cfgHighestWarningSeverity = WARN_INFO
int cfgHighestWarningCode = CFG_WARN_NONE

if cfgBosRequested and not cfgBosDependencyValid
    cfgWarningCount += 1
    cfgHighestWarningSeverity := WARN_INVALID
    cfgHighestWarningCode := CFG_WARN_BOS_REQUIRES_STRUCTURE

if cfgLiquidityRequested and not cfgLiquidityStructureValid
    cfgWarningCount += 1

    if cfgHighestWarningSeverity < WARN_INVALID
        cfgHighestWarningSeverity := WARN_INVALID
        cfgHighestWarningCode := CFG_WARN_LIQUIDITY_REQUIRES_STRUCTURE

if cfgLiquidityRequested and
   cfgLiquidityStructureValid and
   not cfgLiquidityBosValid
    cfgWarningCount += 1

    if cfgHighestWarningSeverity < WARN_INVALID
        cfgHighestWarningSeverity := WARN_INVALID
        cfgHighestWarningCode := CFG_WARN_LIQUIDITY_REQUIRES_BOS

if cfgWyckoffRequested and not cfgWyckoffDependencyValid
    cfgWarningCount += 1

    if cfgHighestWarningSeverity < WARN_INVALID
        cfgHighestWarningSeverity := WARN_INVALID
        cfgHighestWarningCode := CFG_WARN_WYCKOFF_REQUIRES_STRUCTURE

if cfgScoringEnabled and
   cfgAvailableScoringModuleCount <
   cfgProfileSettings.minimumConfirmingModules
    cfgWarningCount += 1

    if cfgHighestWarningSeverity < WARN_DEGRADED
        cfgHighestWarningSeverity := WARN_DEGRADED
        cfgHighestWarningCode := CFG_WARN_SCORING_INSUFFICIENT_MODULES

bool cfgConfigurationValid =
     cfgHighestWarningSeverity < WARN_CRITICAL

// Publish one immutable effective-settings snapshot for this execution.
EffectiveSettings cfgOutput = EffectiveSettings.new(
     cfgIndicatorEnabled,

     cfgProfileId,
     cfgConfirmationModeId,
     cfgConfirmedBarOnly,
     cfgDevelopingAllowed,
     cfgProductionEventAllowed,

     inputAtrLength,
     inputMinimumHistoryBars,

     cfgTrendEnabled,
     cfgRvolEnabled,
     cfgStructureEnabled,

     cfgBosRequested,
     cfgBosDependencyValid,

     cfgLiquidityRequested,
     cfgLiquidityDependencyValid,

     cfgVpaEnabled,

     cfgWyckoffRequested,
     cfgWyckoffDependencyValid,

     cfgInstitutionalEnabled,
     cfgScoringEnabled,
     cfgDashboardEnabled,
     cfgAlertsEnabled,

     cfgProfileSettings.minimumSignalConfidence,
     cfgProfileSettings.minimumSetupQuality,
     cfgProfileSettings.minimumEntryReadiness,
     cfgProfileSettings.minimumConfirmingModules,
     cfgProfileSettings.directionalDominance,
     cfgProfileSettings.stateConfirmationBars,
     cfgProfileSettings.minimumAlertConfidence,
     cfgProfileSettings.alertCooldownBars,

     cfgConfigurationValid,
     cfgWarningCount,
     cfgHighestWarningSeverity,
     cfgHighestWarningCode
)

// =============================================================================
// 08. FRAMEWORK CONTEXT
// =============================================================================

float fwAtr = ta.atr(inputAtrLength)

bool fwVolumeAvailable = not na(volume)
bool fwMinimumHistoryMet =
     bar_index >= cfgOutput.minimumHistoryBars - 1

FrameworkOutput fwOutput = FrameworkOutput.new(
        cfgOutput.indicatorEnabled,  
     bar_index,
     barstate.isconfirmed,
     barstate.isrealtime,
     barstate.ishistory,
     syminfo.tickerid,
     timeframe.period,
     syminfo.mintick,
     fwAtr,
     fwVolumeAvailable,
     fwMinimumHistoryMet,
     inputDebugEnabled
)
// =============================================================================
// 08A. TREND ENGINE CALCULATIONS
// =============================================================================

// Configuration validation.
bool trConfigurationValid =
     inputTrendFastLength < inputTrendSlowLength and
     inputTrendThreshold <= inputTrendStrongThreshold

// Pine built-ins receive the original input-qualified lengths.
float trFastEma =
     ta.ema(close, inputTrendFastLength)

float trSlowEma =
     ta.ema(close, inputTrendSlowLength)

// Trend-specific history requirements.
int trRequiredHistory =
     math.max(
         inputTrendSlowLength,
         inputTrendSlopeLookback + 1
     )

bool trSufficientHistory =
     fwOutput.minimumHistoryMet and
     bar_index >= trRequiredHistory - 1

bool trValuesValid =
     not na(trFastEma) and
     not na(trSlowEma) and
     not na(fwOutput.atr) and
     fwOutput.atr > 0.0

bool trAvailable =
     cfgOutput.trendEnabled and
     trConfigurationValid and
     trSufficientHistory and
     trValuesValid

// ATR-normalised EMA slopes.
float trFastSlopeAtr =
     trendSlopeAtr(
          trFastEma,
          trFastEma[inputTrendSlopeLookback],
          fwOutput.atr
     )

float trSlowSlopeAtr =
     trendSlopeAtr(
          trSlowEma,
          trSlowEma[inputTrendSlopeLookback],
          fwOutput.atr
     )

// Current alignment and slope classifications.
int trAlignmentState =
     resolveTrendAlignment(
          close,
          trFastEma,
          trSlowEma
     )

int trSlopeState =
     resolveTrendSlopeState(
          trFastSlopeAtr,
          trSlowSlopeAtr,
          inputTrendSlopeThresholdAtr
     )

// Normalised component strengths.
float trFastSlopeStrength =
     trendNormalisedStrength(
          trFastSlopeAtr,
          inputTrendSlopeThresholdAtr * 2.0
     )

float trSlowSlopeStrength =
     trendNormalisedStrength(
          trSlowSlopeAtr,
          inputTrendSlopeThresholdAtr * 2.0
     )

float trSeparationAtr =
     safeDivide(
          math.abs(trFastEma - trSlowEma),
          fwOutput.atr,
          0.0
     )

float trSeparationStrength =
     trendNormalisedStrength(
          trSeparationAtr,
          0.50
     )

// Independent bullish and bearish scores.
//
// Maximum contribution:
// Alignment       40
// Fast slope      25
// Slow slope      15
// EMA separation  20
// Total          100
float trBullishScore = 0.0
float trBearishScore = 0.0

if trAvailable
    if trAlignmentState == TREND_ALIGN_BULLISH
        trBullishScore += 40.0
    else if trAlignmentState == TREND_ALIGN_BEARISH
        trBearishScore += 40.0

    if trFastSlopeAtr > 0.0
        trBullishScore += 25.0 * trFastSlopeStrength
    else if trFastSlopeAtr < 0.0
        trBearishScore += 25.0 * trFastSlopeStrength

    if trSlowSlopeAtr > 0.0
        trBullishScore += 15.0 * trSlowSlopeStrength
    else if trSlowSlopeAtr < 0.0
        trBearishScore += 15.0 * trSlowSlopeStrength

    if trFastEma > trSlowEma
        trBullishScore += 20.0 * trSeparationStrength
    else if trFastEma < trSlowEma
        trBearishScore += 20.0 * trSeparationStrength

trBullishScore :=
     clampConfidence(trBullishScore)

trBearishScore :=
     clampConfidence(trBearishScore)

// Current resolved analytical state.
//
// Candidate analytical state used by the confirmed Trend state machine.
int trResolvedState =
     resolveTrendState(
          trAvailable,
          trBullishScore,
          trBearishScore,
          inputTrendThreshold,
          inputTrendStrongThreshold,
          inputTrendDominanceThreshold
     )

int trResolvedDirection =
     trendStateToDirection(trResolvedState)

float trResolvedConfidence =
     resolveTrendConfidence(
          trAvailable,
          trResolvedState,
          trBullishScore,
          trBearishScore
     )

float trResolvedStrength =
     math.max(
          trBullishScore,
          trBearishScore
     )
// =============================================================================
// Confirmed Trend state machine
// =============================================================================

// Persistent values survive across bars.
var int trConfirmedState = TREND_UNAVAILABLE
var int trPreviousConfirmedState = TREND_UNAVAILABLE

var int trPendingState = TREND_UNAVAILABLE
var int trPendingBars = 0
var int trPendingCreationBar = na

var int trTrendEventId = 0
var int trLastEventCreationBar = na
var int trLastEventConfirmationBar = na

// This resets on every script execution and becomes true only on the bar
// where a confirmed transition is published.
bool trNewTrendEvent = false

int trRequiredConfirmationBars =
     math.max(
          1,
          cfgOutput.stateConfirmationBars
     )

int trTransitionTarget = resolveTrendTransitionTarget(trConfirmedState, trResolvedState)

if barstate.isconfirmed
    if not cfgOutput.trendEnabled
        trPendingState := TREND_UNAVAILABLE
        trPendingBars := 0
        trPendingCreationBar := na

        if trConfirmedState != TREND_UNAVAILABLE
            trPreviousConfirmedState := trConfirmedState
            trConfirmedState := TREND_UNAVAILABLE

            trTrendEventId += 1
            trLastEventCreationBar := bar_index
            trLastEventConfirmationBar := bar_index
            trNewTrendEvent := true

    else if not trAvailable
        trPendingState := TREND_UNAVAILABLE
        trPendingBars := 0
        trPendingCreationBar := na

        if trConfirmedState != TREND_UNAVAILABLE
            trPreviousConfirmedState := trConfirmedState
            trConfirmedState := TREND_UNAVAILABLE

            trTrendEventId += 1
            trLastEventCreationBar := bar_index
            trLastEventConfirmationBar := bar_index
            trNewTrendEvent := true

    else if trTransitionTarget == trConfirmedState
        trPendingState := trConfirmedState
        trPendingBars := 0
        trPendingCreationBar := na

    else
        if trTransitionTarget != trPendingState
            trPendingState := trTransitionTarget
            trPendingBars := 1
            trPendingCreationBar := bar_index
        else
            trPendingBars += 1

        if trPendingBars >= trRequiredConfirmationBars
            trPreviousConfirmedState := trConfirmedState
            trConfirmedState := trPendingState

            trTrendEventId += 1
            trLastEventCreationBar := trPendingCreationBar
            trLastEventConfirmationBar := bar_index
            trNewTrendEvent := true

            trPendingState := trConfirmedState
            trPendingBars := 0
            trPendingCreationBar := na
int trPublishedDirection = trendStateToDirection(trConfirmedState)

float trPublishedConfidence = resolveTrendConfidence(trAvailable, trConfirmedState, trBullishScore, trBearishScore)
int trLifecycle =
     not cfgOutput.trendEnabled
          ? LIFE_DISABLED
          : trAvailable
              ? LIFE_CONFIRMED
              : LIFE_UNAVAILABLE

// Publish the confirmed Trend state and immutable transition metadata.
ModuleOutput trBaseOutput =
     ModuleOutput.new(
          cfgOutput.trendEnabled,
          trAvailable,
          trSufficientHistory,
          trConfigurationValid,
          true,
          trConfirmedState,
          trPublishedDirection,
          trLifecycle,
          trPublishedConfidence,
          trTrendEventId,
          trNewTrendEvent,
          trLastEventCreationBar,
          trLastEventConfirmationBar
     )

TrendOutput trTrendOutput =
     TrendOutput.new(
          trBaseOutput,

          trConfirmedState,
          trPreviousConfirmedState,
          trPublishedDirection,

          trResolvedStrength,
          trPublishedConfidence,
          trBullishScore,
          trBearishScore,

          trFastEma,
          trSlowEma,
          trFastSlopeAtr,
          trSlowSlopeAtr,

          trSlopeState,
          trAlignmentState,

          trNewTrendEvent,
          trTrendEventId
     )

// =============================================================================
// 09. EMPTY MODULE OUTPUT FACTORY
// =============================================================================

newEmptyModuleOutput(
     bool enabled,
     bool dependencyValid
) =>
    bool available =
         enabled and
         dependencyValid and
         fwOutput.minimumHistoryMet

    int lifecycle =
         not enabled
             ? LIFE_DISABLED
             : available
                 ? LIFE_CONFIRMED
                 : LIFE_UNAVAILABLE

    ModuleOutput.new(
         enabled,
         available,
         fwOutput.minimumHistoryMet,
         true,
         dependencyValid,
         0,
         DIR_NEUTRAL,
         lifecycle,
         0.0,
         0,
         false,
         na,
         na
     )

// =============================================================================
// 10. MODULE STUB OUTPUTS
// =============================================================================

ModuleOutput trOutput =
     trTrendOutput.baseOutput

ModuleOutput rvOutput = newEmptyModuleOutput(
     cfgOutput.rvolEnabled,
     true
)

ModuleOutput msOutput = newEmptyModuleOutput(
     cfgOutput.structureEnabled,
     true
)

ModuleOutput bcOutput = newEmptyModuleOutput(
     cfgOutput.bosRequested,
     cfgOutput.bosDependencyValid
)

ModuleOutput lqOutput = newEmptyModuleOutput(
     cfgOutput.liquidityRequested,
     cfgOutput.liquidityDependencyValid
)

ModuleOutput vpOutput = newEmptyModuleOutput(
     cfgOutput.vpaEnabled,
     true
)

ModuleOutput wyOutput = newEmptyModuleOutput(
     cfgOutput.wyckoffRequested,
     cfgOutput.wyckoffDependencyValid
)

ModuleOutput inOutput = newEmptyModuleOutput(
     cfgOutput.institutionalEnabled,
     true
)

ModuleOutput scOutput = newEmptyModuleOutput(
     cfgOutput.scoringEnabled,
     true
)

// =============================================================================
// 11. PIPELINE PLACEHOLDERS
// =============================================================================

// Future processing order:
//
// 01. Effective Settings
// 02. Framework
// 03. Trend
// 04. RVOL
// 05. Market Structure
// 06. BOS and CHOCH
// 07. Liquidity
// 08. VPA
// 09. Wyckoff
// 10. Shared Evidence
// 11. Institutional Activity
// 12. Signal Scoring
// 13. Dashboard
// 14. Alerts
// 15. Cleanup and Debug
// =============================================================================
// 11A. TREND VISUALS
// =============================================================================

plot(
     inputShowTrendAverages and trAvailable
          ? trTrendOutput.fastEma
          : na,
     title = "Trend — Fast EMA",
     linewidth = 2
)

plot(
     inputShowTrendAverages and trAvailable
          ? trTrendOutput.slowEma
          : na,
     title = "Trend — Slow EMA",
     linewidth = 2
)

// =============================================================================
// 12. DEBUG OUTPUTS
// =============================================================================

// These hidden plots make early framework values inspectable through the
// TradingView Data Window without adding visible chart clutter.
plot(
     inputDebugEnabled ? trTrendOutput.trendState : na,
     title = "Debug — Trend State",
     display = display.data_window
)
plot(
     inputDebugEnabled ? trResolvedState : na,
     title = "Debug — Trend Candidate State",
     display = display.data_window
)

plot(
     inputDebugEnabled ? trTrendOutput.previousTrendState : na,
     title = "Debug — Previous Trend State",
     display = display.data_window
)

plot(
     inputDebugEnabled ? trPendingState : na,
     title = "Debug — Pending Trend State",
     display = display.data_window
)

plot(
     inputDebugEnabled ? trPendingBars : na,
     title = "Debug — Pending Trend Bars",
     display = display.data_window
)

plot(
     inputDebugEnabled ? (trNewTrendEvent ? 1 : 0) : na,
     title = "Debug — New Trend Event",
     display = display.data_window
)

plot(
     inputDebugEnabled ? trTrendEventId : na,
     title = "Debug — Trend Event ID",
     display = display.data_window
)
plot(
     inputDebugEnabled ? trTrendOutput.trendDirection : na,
     title = "Debug — Trend Direction",
     display = display.data_window
)

plot(
     inputDebugEnabled ? trTrendOutput.trendConfidence : na,
     title = "Debug — Trend Confidence",
     display = display.data_window
)

plot(
     inputDebugEnabled ? trTrendOutput.trendStrength : na,
     title = "Debug — Trend Strength",
     display = display.data_window
)

plot(
     inputDebugEnabled ? trTrendOutput.bullishScore : na,
     title = "Debug — Trend Bullish Score",
     display = display.data_window
)

plot(
     inputDebugEnabled ? trTrendOutput.bearishScore : na,
     title = "Debug — Trend Bearish Score",
     display = display.data_window
)

plot(
     inputDebugEnabled ? trTrendOutput.fastSlopeAtr : na,
     title = "Debug — Trend Fast Slope ATR",
     display = display.data_window
)

plot(
     inputDebugEnabled ? trTrendOutput.slowSlopeAtr : na,
     title = "Debug — Trend Slow Slope ATR",
     display = display.data_window
)

plot(
     inputDebugEnabled ? trTrendOutput.slopeState : na,
     title = "Debug — Trend Slope State",
     display = display.data_window
)

plot(
     inputDebugEnabled ? trTrendOutput.alignmentState : na,
     title = "Debug — Trend Alignment State",
     display = display.data_window
)

plot(
     inputDebugEnabled ? fwOutput.atr : na,
     title = "Debug — Shared ATR",
     display = display.data_window
)

plot(
     inputDebugEnabled ? bar_index : na,
     title = "Debug — Bar Index",
     display = display.data_window
)

plot(
     inputDebugEnabled ? (fwOutput.minimumHistoryMet ? 1 : 0) : na,
     title = "Debug — Minimum History Met",
     display = display.data_window
)

plot(
     inputDebugEnabled ? (fwOutput.volumeAvailable ? 1 : 0) : na,
     title = "Debug — Volume Available",
     display = display.data_window
)
plot(
     inputDebugEnabled ? cfgOutput.profile : na,
     title = "Debug — Profile ID",
     display = display.data_window
)

plot(
     inputDebugEnabled ? cfgOutput.confirmationMode : na,
     title = "Debug — Confirmation Mode ID",
     display = display.data_window
)

plot(
     inputDebugEnabled ? cfgOutput.minimumSignalConfidence : na,
     title = "Debug — Minimum Signal Confidence",
     display = display.data_window
)

plot(
     inputDebugEnabled ? cfgOutput.minimumSetupQuality : na,
     title = "Debug — Minimum Setup Quality",
     display = display.data_window
)

plot(
     inputDebugEnabled ? cfgOutput.minimumEntryReadiness : na,
     title = "Debug — Minimum Entry Readiness",
     display = display.data_window
)

plot(
     inputDebugEnabled ? cfgOutput.minimumConfirmingModules : na,
     title = "Debug — Minimum Confirming Modules",
     display = display.data_window
)

plot(
     inputDebugEnabled ? cfgOutput.warningCount : na,
     title = "Debug — Configuration Warning Count",
     display = display.data_window
)

plot(
     inputDebugEnabled ? cfgOutput.highestWarningSeverity : na,
     title = "Debug — Highest Warning Severity",
     display = display.data_window
)

plot(
     inputDebugEnabled ? cfgOutput.highestWarningCode : na,
     title = "Debug — Highest Warning Code",
     display = display.data_window
)
plot(
     inputDebugEnabled ? cfgOutput.profile : na,
     title = "Debug — Profile ID",
     display = display.data_window
)

plot(
     inputDebugEnabled ? cfgOutput.confirmationMode : na,
     title = "Debug — Confirmation Mode ID",
     display = display.data_window
)

plot(
     inputDebugEnabled ? cfgOutput.minimumSignalConfidence : na,
     title = "Debug — Minimum Signal Confidence",
     display = display.data_window
)

plot(
     inputDebugEnabled ? cfgOutput.minimumSetupQuality : na,
     title = "Debug — Minimum Setup Quality",
     display = display.data_window
)

plot(
     inputDebugEnabled ? cfgOutput.minimumEntryReadiness : na,
     title = "Debug — Minimum Entry Readiness",
     display = display.data_window
)

plot(
     inputDebugEnabled ? cfgOutput.minimumConfirmingModules : na,
     title = "Debug — Minimum Confirming Modules",
     display = display.data_window
)

plot(
     inputDebugEnabled ? cfgOutput.warningCount : na,
     title = "Debug — Configuration Warning Count",
     display = display.data_window
)

plot(
     inputDebugEnabled ? cfgOutput.highestWarningSeverity : na,
     title = "Debug — Highest Warning Severity",
     display = display.data_window
